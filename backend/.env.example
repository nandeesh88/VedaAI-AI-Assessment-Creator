# MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>

# Redis URL (supports redis:// and rediss://)
REDIS_URL=rediss://<username>:<password>@<host>:<port>

# Groq API key
GROQ_API_KEY=<your_groq_api_key>

# Server port on local/dev; Render usually injects PORT
PORT=4000

# Allowed frontend origins for CORS (comma-separated)
# Example: http://localhost:3000,https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# Runtime environment
NODE_ENV=development

# Optional: public URL used for startup logs on Render
RENDER_EXTERNAL_URL=https://your-backend.onrender.com