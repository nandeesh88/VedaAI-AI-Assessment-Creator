  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build:standalone": "next build && node -e \"const fs=require('fs');const path=require('path');const fromStatic=path.join('.next','static');const toStatic=path.join('.next','standalone','.next','static');if(fs.existsSync(fromStatic)){fs.cpSync(fromStatic,toStatic,{recursive:true});}const fromPublic='public';const toPublic=path.join('.next','standalone','public');if(fs.existsSync(fromPublic)){fs.cpSync(fromPublic,toPublic,{recursive:true});}\"",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "next lint"
  },
